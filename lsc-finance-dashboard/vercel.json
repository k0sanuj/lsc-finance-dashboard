{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm exec -- pnpm install --no-frozen-lockfile",
  "buildCommand": "npm exec -- pnpm --filter web build",
  "outputDirectory": "apps/web/.next",
  "devCommand": "npm exec -- pnpm --filter web dev"
}
