{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next@4.4.2",
      "config": {
        "installCommand": "npm exec -- pnpm install --frozen-lockfile",
        "buildCommand": "npm exec -- pnpm --filter web build && rm -rf .next && cp -R apps/web/.next .next"
      }
    }
  ]
}
