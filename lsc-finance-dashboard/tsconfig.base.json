{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@lsc/db": [
        "packages/db/src/index.ts"
      ],
      "@lsc/db/*": [
        "packages/db/src/*"
      ],
      "@lsc/skills/*": [
        "skills/*"
      ],
      "@lsc/ontology/*": [
        "ontology/*"
      ],
      "@lsc/agents/*": [
        "agents/*"
      ]
    }
  }
}
