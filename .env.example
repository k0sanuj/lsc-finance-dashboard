# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL_ADMIN=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL_APP_READ=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL_IMPORT=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
LSC_DATA_BACKEND=seed
LSC_APP_READ_PASSWORD=
LSC_IMPORT_RW_PASSWORD=
AUTH_SESSION_SECRET=
AUTH_BOOTSTRAP_EMAIL=
AUTH_BOOTSTRAP_NAME=
AUTH_BOOTSTRAP_PASSWORD=

# Optional import integrations
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Optional document storage
DOCUMENT_STORAGE_BACKEND=inline
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=
S3_SIGNED_URL_TTL_SECONDS=900

# Optional AI features
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
